# SMTP connection settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=dein-smtp-benutzername
SMTP_PASS=dein-smtp-passwort

# Empfängeradresse
EMAIL_TO=Amar.Javid@web.de
EMAIL_FROM="Amar's Pizza <no-reply@amars-pizza.de>"

# EmailJS Konfiguration für clientseitigen Versand
VITE_EMAILJS_SERVICE_ID=dein_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=dein_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=dein_emailjs_public_key

# Optional: eigener Serverport für den E-Mail-Service
SERVER_PORT=3000
